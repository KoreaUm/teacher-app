rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function myUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() && myUserDoc().data.role == 'admin';
    }

    function canUseGrades() {
      return signedIn() && (isAdmin() || myUserDoc().data.gradeAccess == true);
    }

    function hasGradeSession() {
      return canUseGrades() &&
        exists(/databases/$(database)/documents/gradeBooks/default/sessions/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/gradeBooks/default/sessions/$(request.auth.uid)).data.active == true &&
        get(/databases/$(database)/documents/gradeBooks/default/sessions/$(request.auth.uid)).data.expiresAt > request.time;
    }

    match /users/{userId} {
      allow create: if isSelf(userId);
      allow read: if isSelf(userId) || isAdmin();

      allow update: if (
        isSelf(userId) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.approved == resource.data.approved &&
        request.resource.data.active == resource.data.active &&
        request.resource.data.gradeAccess == resource.data.gradeAccess
      ) || isAdmin();
    }

    match /users/{userId}/settings/{docId} {
      allow read, write: if isSelf(userId) || isAdmin();
    }

    match /users/{userId}/shared/{docId} {
      allow read, write: if isSelf(userId) || isAdmin();
    }

    match /users/{userId}/session/{docId} {
      allow read, write: if isSelf(userId) || isAdmin();
    }

    match /app/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /gradeBooks/{bookId} {
      allow get: if canUseGrades();
      allow list: if false;
      allow create, update: if hasGradeSession() || isAdmin();
      allow delete: if isAdmin();

      match /scores/{scoreId} {
        allow read, write: if hasGradeSession();
      }

      match /careerStudents/{studentId} {
        allow read, write: if hasGradeSession();
      }

      match /sessions/{userId} {
        allow read: if isSelf(userId) || isAdmin();
        allow create, update: if false;
        allow delete: if isSelf(userId) || isAdmin();
      }
    }

    match /appSecrets/{docId} {
      allow read, write: if false;
    }
  }
}
